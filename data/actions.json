{
  "schemaVersion": 1,
  "description": "Player care action catalog for deterministic Grow Simulator gameplay.",
  "stateVariables": [
    "water",
    "nutrition",
    "health",
    "stress",
    "risk",
    "growth"
  ],
  "schema": {
    "action": {
      "id": "string (unique)",
      "category": "watering|fertilizing|training|environment",
      "intensity": "low|medium|high",
      "label": "string",
      "uxCopy": {
        "short": "string",
        "success": "string",
        "warning": "string"
      },
      "trigger": {
        "timeWindow": "daytime_only|anytime",
        "requiresNoActiveCooldown": true,
        "minStageIndex": "number (0-11)"
      },
      "prerequisites": {
        "min": {
          "water": "number",
          "nutrition": "number",
          "health": "number"
        },
        "max": {
          "water": "number",
          "nutrition": "number",
          "stress": "number",
          "risk": "number"
        }
      },
      "effects": {
        "immediate": {
          "water": "delta",
          "nutrition": "delta",
          "health": "delta",
          "stress": "delta",
          "risk": "delta",
          "growth": "delta"
        },
        "durationSimMinutes": "number",
        "overTime": {
          "waterPerHour": "delta",
          "nutritionPerHour": "delta",
          "healthPerHour": "delta",
          "stressPerHour": "delta",
          "riskPerHour": "delta",
          "growthPerHour": "delta"
        }
      },
      "cooldownRealMinutes": "number",
      "sideEffects": [
        {
          "id": "string",
          "when": "condition expression",
          "chance": "0.0-1.0 deterministic roll",
          "deltas": {
            "water": "delta",
            "nutrition": "delta",
            "health": "delta",
            "stress": "delta",
            "risk": "delta",
            "growth": "delta"
          },
          "note": "string"
        }
      ],
      "riskNotes": "string"
    }
  },
