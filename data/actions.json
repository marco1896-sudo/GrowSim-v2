          "water": "number",
          "nutrition": "number",
          "stress": "number",
          "risk": "number"
        }
      },
      "effects": {
        "immediate": {
          "water": "delta",
          "nutrition": "delta",
          "health": "delta",
          "stress": "delta",
          "risk": "delta",
          "growth": "delta"
        },
        "durationSimMinutes": "number",
        "overTime": {
          "waterPerHour": "delta",
          "nutritionPerHour": "delta",
          "healthPerHour": "delta",
          "stressPerHour": "delta",
          "riskPerHour": "delta",
          "growthPerHour": "delta"
        }
      },
      "rootZoneInfluence": {
        "ecDelta": "delta",
        "phDelta": "delta",
        "phToward": "target ph",
        "phTowardWeight": "0.0-1.0"
      },
      "climateInfluence": {
        "humidityPulsePercent": "small actual tent RH bump"
      },
      "cooldownRealMinutes": "number",
      "sideEffects": [
        {
          "id": "string",
          "when": "condition expression",
          "chance": "0.0-1.0 deterministic roll",
          "deltas": {
            "water": "delta",
            "nutrition": "delta",
            "health": "delta",
            "stress": "delta",
            "risk": "delta",
            "growth": "delta"
          },
          "note": "string"
        }
      ],
      "riskNotes": "string"
    }
  },
