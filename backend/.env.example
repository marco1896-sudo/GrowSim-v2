# Server
NODE_ENV=development
PORT=8080

# Security
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS
# Comma-separated list, e.g. http://localhost:5173,https://growsim.example.com
CORS_ORIGINS=http://localhost:5173

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/growsim
